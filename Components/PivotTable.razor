@* PivotTable — renders cross-tab with grouped headers for multiple value fields.
   Clicking any data cell opens a drill-down modal. *@

@if (Pivot is null || Pivot.RowKeys.Count == 0)
{
    <div class="alert alert-secondary py-2">
        <i class="bi bi-info-circle me-2"></i>
        No pivot data. Configure the fields above and click <strong>Apply Pivot</strong>.
    </div>
}
else
{
    var vds   = Pivot.ValueDefs;
    int nv    = vds.Count;
    bool multi = nv > 1;

    <div class="pivot-table-wrapper">
        <table class="table table-sm table-bordered pivot-table mb-0">

            @* ══ HEADER ══════════════════════════════════════════════ *@
            <thead>
                @* Row 1: row-label | ColKey (span nv) … | Total (span nv) *@
                <tr>
                    <th class="pivot-corner" rowspan="@(multi ? 2 : 1)">
                        @RowField
                        <span class="text-white-50 mx-1">/</span>
                        @ColField
                    </th>

                    @foreach (var ck in Pivot.ColumnKeys)
                    {
                        @if (multi)
                        {
                            <th class="text-center pivot-col-group" colspan="@nv">@ck</th>
                        }
                        else
                        {
                            <th class="text-end">@ck</th>
                        }
                    }

                    @if (Config?.ShowRowTotals != false)
                    {
                        @if (multi)
                        {
                            <th class="text-center pivot-total-group" colspan="@nv">Total</th>
                        }
                        else
                        {
                            <th class="text-end pivot-total-group">Total</th>
                        }
                    }
                </tr>

                @* Row 2 (multi-value only): value-field sub-headers *@
                @if (multi)
                {
                    <tr>
                        @foreach (var ck in Pivot.ColumnKeys)
                        {
                            @foreach (var vd in vds)
                            {
                                <th class="text-end pivot-sub-hdr" title="@vd.Field – @vd.Aggregation">
                                    @vd.Aggregation<br /><small class="fw-normal opacity-75">@vd.Field</small>
                                </th>
                            }
                        }
                        @if (Config?.ShowRowTotals != false)
                        {
                            @foreach (var vd in vds)
                            {
                                <th class="text-end pivot-sub-hdr pivot-total-sub">
                                    @vd.Aggregation<br /><small class="fw-normal opacity-75">@vd.Field</small>
                                </th>
                            }
                        }
                    </tr>
                }
            </thead>

            @* ══ BODY ════════════════════════════════════════════════ *@
            <tbody>
                @foreach (var rk in Pivot.RowKeys)
                {
                    <tr>
                        <td class="pivot-row-label">@rk</td>

                        @foreach (var ck in Pivot.ColumnKeys)
                        {
                            @foreach (var vd in vds)
                            {
                                var val = GetCell(rk, ck, vd.Label);
                                <td class="text-end @(val != null ? "pivot-cell" : "text-muted")"
                                    style="@(val != null ? "cursor:pointer" : "")"
                                    title="@(val != null ? $"Click to drill-down: {rk} / {ck}" : "")"
                                    @onclick="() => DrillDown(rk, ck, val)">
                                    @FmtVal(val)
                                </td>
                            }
                        }

                        @if (Config?.ShowRowTotals != false)
                        {
                            @foreach (var vd in vds)
                            {
                                var tot = GetRowTotal(rk, vd.Label);
                                <td class="text-end fw-semibold pivot-row-total">@FmtVal(tot)</td>
                            }
                        }
                    </tr>
                }
            </tbody>

            @* ══ FOOTER ══════════════════════════════════════════════ *@
            @if (Config?.ShowColTotals != false || Config?.ShowGrandTotal != false)
            {
                <tfoot>
                    <tr>
                        <td class="fw-bold pivot-grand-label">Grand Total</td>

                        @foreach (var ck in Pivot.ColumnKeys)
                        {
                            @foreach (var vd in vds)
                            {
                                var ct = GetColTotal(ck, vd.Label);
                                <td class="text-end fw-bold">@FmtVal(ct)</td>
                            }
                        }

                        @if (Config?.ShowRowTotals != false && Config?.ShowGrandTotal != false)
                        {
                            @foreach (var vd in vds)
                            {
                                var gt = GetGrandTotal(vd.Label);
                                <td class="text-end fw-bold pivot-grand-total">@FmtVal(gt)</td>
                            }
                        }
                    </tr>
                </tfoot>
            }
        </table>
    </div>
}

@* ══ DRILL-DOWN MODAL ══════════════════════════════════════════════ *@
@if (_drillOpen)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.55)" @onclick="CloseDrill">
        <div class="modal-dialog modal-xl modal-dialog-scrollable"
             @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white py-2">
                    <h6 class="modal-title mb-0">
                        <i class="bi bi-zoom-in me-2"></i>
                        Drill-Down &nbsp;
                        <span class="badge bg-secondary">@_drillRowKey</span>
                        <i class="bi bi-x mx-1 opacity-50"></i>
                        <span class="badge bg-primary">@_drillColKey</span>
                        @if (_drillValue != null)
                        {
                            <span class="badge bg-success ms-1">@FmtVal(_drillValue)</span>
                        }
                    </h6>
                    <button class="btn-close btn-close-white" @onclick="CloseDrill"></button>
                </div>

                <div class="modal-body p-0">
                    @if (_drillLoading)
                    {
                        <div class="d-flex justify-content-center py-5">
                            <div class="spinner-border text-primary"></div>
                        </div>
                    }
                    else if (_drillData.Count == 0)
                    {
                        <p class="p-4 text-muted">No detail rows found.</p>
                    }
                    else
                    {
                        @* Column chooser for drill-down *@
                        <div class="px-3 pt-2 d-flex align-items-center gap-2 flex-wrap border-bottom pb-2">
                            <span class="badge bg-secondary">@_drillData.Count.ToString("N0") rows</span>
                            @if (_drillData.Count > 500)
                            {
                                <span class="text-muted small">Showing first 500</span>
                            }
                        </div>

                        <div class="table-responsive">
                            <table class="table table-sm table-striped table-bordered m-0">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        @foreach (var col in _drillCols)
                                        {
                                            <th class="small">@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _drillData.Take(500))
                                    {
                                        <tr>
                                            @foreach (var col in _drillCols)
                                            {
                                                <td class="small">
                                                    @(row.TryGetValue(col, out var v) ? v?.ToString() : "")
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="modal-footer py-2">
                    <span class="me-auto text-muted small">
                        @_drillData.Count.ToString("N0") detail rows
                    </span>
                    <button class="btn btn-secondary btn-sm" @onclick="CloseDrill">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public PivotResult? Pivot { get; set; }

    [Parameter] public string     RowField  { get; set; } = "";
    [Parameter] public string     ColField  { get; set; } = "";
    [Parameter] public PivotConfig? Config  { get; set; }

    [Parameter]
    public Func<Dictionary<string, object?>, Task<IReadOnlyList<Dictionary<string, object?>>>>?
        DrillDownProvider { get; set; }

    // ── Drill-down state ──────────────────────────────────────────
    private bool _drillOpen;
    private bool _drillLoading;
    private string _drillRowKey = "";
    private string _drillColKey = "";
    private object? _drillValue;
    private IReadOnlyList<Dictionary<string, object?>> _drillData = [];
    private IReadOnlyList<string> _drillCols = [];

    // ── Cell helpers ──────────────────────────────────────────────
    private object? GetCell(string rk, string ck, string label) =>
        Pivot!.Data.TryGetValue(rk, out var rd) &&
        rd.TryGetValue(ck, out var cd) &&
        cd.TryGetValue(label, out var v) ? v : null;

    private object? GetRowTotal(string rk, string label) =>
        Pivot!.RowTotals.TryGetValue(rk, out var rd) &&
        rd.TryGetValue(label, out var v) ? v : null;

    private object? GetColTotal(string ck, string label) =>
        Pivot!.ColTotals.TryGetValue(ck, out var cd) &&
        cd.TryGetValue(label, out var v) ? v : null;

    private object? GetGrandTotal(string label) =>
        Pivot!.GrandTotals.TryGetValue(label, out var v) ? v : null;

    private static string FmtVal(object? v) =>
        v is null ? "–"
        : double.TryParse(v.ToString(), out var d) ? d.ToString("N2") : v.ToString()!;

    // ── Drill-down ────────────────────────────────────────────────
    private async Task DrillDown(string rk, string ck, object? val)
    {
        if (val is null || DrillDownProvider is null) return;

        _drillRowKey = rk;
        _drillColKey = ck;
        _drillValue  = val;
        _drillOpen   = true;
        _drillLoading = true;
        _drillData   = [];
        StateHasChanged();

        try
        {
            var filters = new Dictionary<string, object?>
            {
                [RowField] = rk,
                [ColField] = ck
            };
            _drillData = await DrillDownProvider(filters);
            _drillCols = _drillData.Count > 0 ? _drillData[0].Keys.ToList() : [];
        }
        finally
        {
            _drillLoading = false;
            StateHasChanged();
        }
    }

    private void CloseDrill()
    {
        _drillOpen = false;
        _drillData = [];
        _drillCols = [];
    }
}
