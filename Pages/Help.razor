                        </tr>
                        <tr>
                            <td><kbd>Esc</kbd></td>
                            <td>Column alias input</td>
                            <td>Cancel renaming, restore previous name</td>
                        </tr>
                        <tr>
                            <td>Double-click header</td>
                            <td>Data grid</td>
                            <td>Enter column rename mode</td>
                        </tr>
                        <tr>
                            <td>Click header</td>
                            <td>Data grid</td>
                            <td>Toggle sort ascending / descending</td>
                        </tr>
                        <tr>
                            <td>Drag header</td>
                            <td>Data grid</td>
                            <td>Reorder the column</td>
                        </tr>
                        <tr>
                            <td>Click pivot cell</td>
                            <td>Pivot table</td>
                            <td>Open drill-down modal for that intersection</td>
                        </tr>
                        <tr>
                            <td>Click backdrop</td>
