@page "/"
<PageTitle>Home – DMSPRO  Reporting</PageTitle>

<div class="container py-5">
    <div class="text-center mb-5">
        <i class="bi bi-bar-chart-fill display-1 text-primary"></i>
        <h1 class="mt-3">DMSPRO Reporting</h1>
        <p class="lead text-muted">Dynamic SQL Server reports with pivot, drill-down, and export.</p>
        @* <a class="btn btn-primary btn-lg mt-2"
           href="/report?Source=sp_DMS_RPT_ReportMasterDistributor&Type=SP&CompanyID=3">
            <i class="bi bi-play-fill me-2"></i>Master Distributor Report (CompanyID=3)
        </a> *@
    </div>

    @* ── Quick report links ── *@
    <div class="row g-3 mb-5">
        <div class="col-12">
            <h5 class="text-muted mb-3">Quick Reports</h5>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-primary">
                <div class="card-body">
                    <h6 class="card-title fw-bold">
                        <i class="bi bi-people-fill me-2 text-primary"></i>Master Distributor
                    </h6>
                    <p class="card-text small text-muted mb-2">
                        <code>sp_DMS_RPT_ReportMasterDistributor</code><br/>
                        Params: CompanyID, ProvinceID, ChannelID, SalesAreaID
                    </p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a class="btn btn-sm btn-primary"
                           href="/report?Source=sp_DMS_RPT_ReportMasterDistributor&Type=SP&CompanyID=3">
                            CompanyID = 3
                        </a>
                        <a class="btn btn-sm btn-outline-primary"
                           href="/report?Source=sp_DMS_RPT_ReportMasterDistributor&Type=SP">
                            All (no filter)
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-database me-2 text-primary"></i>Flexible Sources</h5>
                    <p class="card-text text-muted">Connect to Stored Procedures, Views, or Tables with runtime parameters.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-grid-3x3-gap me-2 text-success"></i>Pivot Analysis</h5>
                    <p class="card-text text-muted">Cross-tabulate any columns, save layouts per user, drill into cells.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-download me-2 text-danger"></i>Export Anywhere</h5>
                    <p class="card-text text-muted">Download as Excel, CSV, or PDF — raw or pivot layout.</p>
                </div>
            </div>
        </div>
    </div>
</div>
