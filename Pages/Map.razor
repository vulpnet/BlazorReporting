    // ── Gọi từ popup button trên bản đồ ─────────────────
    [JSInvokable]
    public async Task ShowRouteByNameAsync(string userName)
    {
        var loc = _locations.FirstOrDefault(l =>
            l.UserName.Equals(userName, StringComparison.OrdinalIgnoreCase));
        if (loc == null) return;

        var idx = _locations
            .Select((l, i) => (l, i))
