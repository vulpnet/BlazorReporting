@page "/map"
@using BlazorReporting.Data
@using BlazorReporting.Services
@using System.Text.Json
@inject IDataRepository Repo
@inject SalesForecastService Forecaster
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Bản đồ Salesman – DMSPRO</PageTitle>

@* ══ TOOLBAR ══════════════════════════════════════════ *@
<div class="map-toolbar">
    <div class="d-flex align-items-center gap-2 flex-wrap">

        <div class="d-flex align-items-center gap-2 me-2">
            <div class="map-title-icon"><i class="bi bi-geo-alt-fill"></i></div>
            <div>
                <div class="map-title">Bản đồ vị trí Salesman</div>
                <div class="map-subtitle">DMSAimSalesmanLocation — vị trí cuối cùng trong ngày</div>
            </div>
        </div>

        @* ── Custom Calendar Picker ── *@
        <div class="cal-wrap">
            <button class="cal-trigger @(_showDatePicker ? "cal-trigger--open" : "")"
                    @onclick="ToggleDatePicker" disabled="@_loading">
                <i class="bi bi-calendar3 cal-trigger-icon"></i>
                <span>@_date.ToString("dd/MM/yyyy")</span>
                <i class="bi bi-chevron-down cal-trigger-caret @(_showDatePicker ? "cal-trigger-caret--up" : "")"></i>
            </button>

            @if (_showDatePicker)
            {
                <div class="cal-backdrop" @onclick="() => _showDatePicker = false"></div>
                <div class="cal-popup" @onclick:stopPropagation="true">

                    @* Header *@
                    <div class="cal-header">
                        <button class="cal-nav" @onclick="CalPrevMonth">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <span class="cal-month-year">
                            @(System.Globalization.CultureInfo.GetCultureInfo("en-US")
                                .DateTimeFormat.GetMonthName(_calMonth))
                            &nbsp;
                            <span class="cal-year">@_calYear</span>
                        </span>
                        <button class="cal-nav" @onclick="CalNextMonth">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>

                    @* Day-of-week headers *@
                    <div class="cal-grid">
                        @foreach (var d in new[] {"Sun","Mon","Tue","Wed","Thu","Fri","Sat"})
                        {
                            <div class="cal-dow">@d</div>
                        }

                        @{
                            var firstDay     = new DateTime(_calYear, _calMonth, 1);
                            var startDow     = (int)firstDay.DayOfWeek;   // Sun=0
                            var daysInMonth  = DateTime.DaysInMonth(_calYear, _calMonth);
                            var prevDays     = DateTime.DaysInMonth(
                                                  _calMonth == 1 ? _calYear - 1 : _calYear,
                                                  _calMonth == 1 ? 12 : _calMonth - 1);
                            var today        = DateTime.Today;

                            // Prev-month trailing days
                            for (int e = 0; e < startDow; e++)
                            {
                                var pd = new DateTime(
                                    _calMonth == 1 ? _calYear - 1 : _calYear,
                                    _calMonth == 1 ? 12 : _calMonth - 1,
                                    prevDays - startDow + 1 + e);
                                var pCls = "cal-cell cal-cell--other";
                                <div class="@pCls" @onclick="() => SelectCalDate(pd)">@pd.Day</div>
                            }

                            // Current month days
                            for (int d = 1; d <= daysInMonth; d++)
                            {
                                var thisDate   = new DateTime(_calYear, _calMonth, d);
                                var isToday    = thisDate == today;
                                var isSelected = thisDate.Date == _date.Date;
                                var cls = "cal-cell"
                                    + (isSelected ? " cal-cell--selected" : "")
                                    + (isToday && !isSelected ? " cal-cell--today" : "");
                                <div class="@cls" @onclick="() => SelectCalDate(thisDate)">@d</div>
                            }

                            // Next-month leading days
                            int total     = startDow + daysInMonth;
                            int remainder = total % 7 == 0 ? 0 : 7 - (total % 7);
                            for (int e = 1; e <= remainder; e++)
                            {
                                var nd = new DateTime(
                                    _calMonth == 12 ? _calYear + 1 : _calYear,
                                    _calMonth == 12 ? 1 : _calMonth + 1,
                                    e);
                                <div class="cal-cell cal-cell--other" @onclick="() => SelectCalDate(nd)">@nd.Day</div>
                            }
                        }
                    </div>

                    @* Today shortcut *@
                    <div class="cal-footer">
                        <button class="cal-today-btn" @onclick="GoToToday">Today</button>
                    </div>
                </div>
            }
        </div>

        <button class="btn btn-primary btn-sm d-flex align-items-center gap-1"
                @onclick="LoadAsync" disabled="@_loading">
            @if (_loading)
            { <span class="spinner-border spinner-border-sm"></span><span>Đang tải…</span> }
            else
            { <i class="bi bi-search"></i><span>Xem bản đồ</span> }
        </button>

        @if (_locations.Count > 0)
        {
            <span class="badge map-badge-total">
                <i class="bi bi-people-fill me-1"></i>@_locations.Count salesman
            </span>
            @if (_geocodingStarted && _geocodedCount < _locations.Count)
            {
                <span class="badge bg-secondary" style="font-size:.68rem">
                    <span class="spinner-border spinner-border-sm me-1"
                          style="width:.6rem;height:.6rem;border-width:1.5px"></span>
                    Địa chỉ @_geocodedCount/@_locations.Count
                </span>
            }

            @* ── Nút chart ── *@
            <div class="btn-group btn-group-sm">
                <button class="btn @(_showChart ? "btn-primary" : "btn-outline-primary") d-flex align-items-center gap-1"
                        @onclick="ToggleChartAsync" title="Biểu đồ doanh số theo khu vực">
                    <i class="bi bi-bar-chart-fill"></i>
                    <span class="d-none d-sm-inline">Doanh số</span>
                </button>
                <button class="btn @(_showProductPanel ? "btn-warning" : "btn-outline-warning") d-flex align-items-center gap-1"
                        @onclick="ToggleProductPanelAsync" title="Phân tích sản phẩm">
                    <i class="bi bi-box-seam-fill"></i>
                    <span class="d-none d-sm-inline">Sản phẩm</span>
                </button>
            </div>

            <div class="input-group input-group-sm ms-auto" style="width:210px">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input class="form-control" placeholder="Tìm username / địa chỉ…"
                       @bind="_search" @bind:event="oninput" />
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-2 mb-0 py-1 px-2" style="font-size:.82rem">
            <i class="bi bi-exclamation-triangle me-1"></i>@_error
        </div>
    }
</div>

@* ══ LAYOUT ═══════════════════════════════════════════ *@
<div class="map-layout">

    @* ── Bản đồ ── *@
    <div class="map-container">
        <div id="leaflet-map"></div>

        @if (!_mapReady)
        {
            <div class="map-placeholder">
                <div class="text-center text-muted">
                    <i class="bi bi-map display-1 opacity-25 d-block mb-3"></i>
                    <p class="mb-0">Chọn ngày và nhấn <strong>Xem bản đồ</strong></p>
                </div>
            </div>
        }

        @if (_loading)
        {
            <div class="map-overlay">
                <div class="spinner-border text-primary" style="width:2.5rem;height:2.5rem"></div>
                <div class="mt-2 fw-semibold" style="color:#fff">Đang tải dữ liệu…</div>
            </div>
        }

        @* ── Route info panel (floating trên map) ── *@
        @if (_routeInfo != null)
        {
            <div class="map-route-panel">
                <div class="map-route-panel-header">
                    <div class="d-flex align-items-center gap-2">
                        <div class="map-route-avatar" style="background:@IndexColor(_routeColorIdx)">
                            @AvatarText(_routeInfo.UserName)
                        </div>
                        <div>
                            <div class="map-route-name">@_routeInfo.UserName</div>
                            <div class="map-route-date">@_date.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <button class="map-route-close" @onclick="ClearRouteAsync" title="Đóng lộ trình">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="map-route-stats">
                    <div class="map-route-stat">
                        <i class="bi bi-geo-fill text-success"></i>
                        <span>@_routeInfo.Stops điểm GPS</span>
                    </div>
                    <div class="map-route-stat">
                        <i class="bi bi-shop text-warning"></i>
                        <span>@_routeInfo.CustomerStops KH</span>
                    </div>
                    <div class="map-route-stat">
                        <i class="bi bi-clock text-primary"></i>
                        <span>@_routeInfo.TimeRange</span>
                    </div>
                    <div class="map-route-stat">
                        <i class="bi bi-signpost-2 text-secondary"></i>
                        <span>~@_routeInfo.Km km</span>
                    </div>
                    @if (_routeInfo.TotalSales > 0)
                    {
                        <div class="map-route-stat map-route-stat--sales">
                            <i class="bi bi-currency-dollar"></i>
                            <span>@FormatMoney(_routeInfo.TotalSales)</span>
                        </div>
                    }
                </div>
            </div>
        }

        @if (_routeLoading)
        {
            <div class="map-overlay" style="background:rgba(15,23,42,.35)">
                <div class="spinner-border text-white"></div>
                <div class="mt-2 text-white fw-semibold" style="font-size:.85rem">
                    Đang tải lộ trình…
                </div>
            </div>
        }

        @* ── Chart panel trượt lên từ dưới ── *@
        @if (_showChart)
        {
            <div class="map-chart-panel">

                @* Header *@
                <div class="map-chart-header">
                    @* Trái: tiêu đề + tổng *@
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <i class="bi bi-bar-chart-fill text-primary"></i>
                        <span class="fw-bold" style="font-size:.88rem">
                            Doanh số @_date.ToString("dd/MM/yyyy")
                        </span>
                        @if (_chartTotal > 0)
                        {
                            <span class="badge bg-success" style="font-size:.7rem">
                                Tổng: @FormatMoney(_chartTotal)
                            </span>
                            <span class="badge bg-secondary" style="font-size:.7rem">
                                @_chartData.Count mục
                            </span>
                        }
                    </div>

                    @* Phải: controls *@
                    <div class="d-flex align-items-center gap-2 flex-wrap">

                        @* Loại nhóm *@
                        <select class="form-select form-select-sm chart-ctrl-select"
                                @bind="_chartGroupBy" @bind:after="RefreshChartAsync">
                            <option value="route">🗺 Tuyến</option>
                            <option value="sm">👤 Salesman</option>
                            <option value="province">🏙 Tỉnh/TP</option>
                            <option value="channel">📦 Kênh</option>
                        </select>

                        @* Loại biểu đồ *@
                        <div class="chart-type-group">
                            @foreach (var (typ, ico, lbl) in ChartTypes)
                            {
                                var t = typ;
                                <button class="chart-type-btn @(_chartType == t ? "active" : "")"
                                        title="@lbl" @onclick="() => SwitchChartType(t)">
                                    <i class="bi @ico"></i>
                                </button>
                            }
                        </div>

                        @if (_chartLoading)
                        {
                            <span class="spinner-border spinner-border-sm text-primary"></span>
                        }
                        <button class="btn btn-sm btn-outline-secondary p-1"
                                @onclick="() => _showChart = false" title="Đóng">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                </div>

                @* Body *@
                <div class="map-chart-body">
                    @if (_chartLoading)
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                            <div class="spinner-border me-2"></div>Đang tải…
                        </div>
                    }
                    else if (_chartData.Count == 0)
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                            <i class="bi bi-inbox me-2"></i>Không có dữ liệu
                        </div>
                    }
                    else
                    {
                        @* Scroll wrapper cho bar ngang nhiều item *@
                        <div class="chart-scroll-wrap">
                            <canvas id="sales-chart"></canvas>
                        </div>
                    }
                </div>
            </div>
        }

        @* ── Product Analysis Panel ── *@
        @if (_showProductPanel)
        {
            <div class="map-ps-panel">

                @* Header / filters *@
                <div class="map-ps-header">
                    <i class="bi bi-box-seam-fill text-warning me-1"></i>
                    <span class="fw-bold me-2" style="font-size:.85rem">Phân tích sản phẩm</span>

                    <select class="form-select form-select-sm ps-select" @bind="_psYear" disabled="@_psLoading">
                        @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 4; y--)
                        { var yy = y; <option value="@yy">@yy</option> }
                    </select>

                    <select class="form-select form-select-sm ps-select" @bind="_psPeriodType"
                            @bind:after="OnPsPeriodTypeChanged" disabled="@_psLoading">
                        <option value="year">Cả năm</option>
                        <option value="quarter">Quý</option>
                        <option value="month">Tháng</option>
                    </select>

                    @if (_psPeriodType == "quarter")
                    {
                        <select class="form-select form-select-sm ps-select" @bind="_psPeriodValue" disabled="@_psLoading">
                            <option value="1">Q1</option>
                            <option value="2">Q2</option>
                            <option value="3">Q3</option>
                            <option value="4">Q4</option>
                        </select>
                    }
                    else if (_psPeriodType == "month")
                    {
                        <select class="form-select form-select-sm ps-select" @bind="_psPeriodValue" disabled="@_psLoading">
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m">Tháng @m</option>
                            }
                        </select>
                    }

                    <select class="form-select form-select-sm ps-select" @bind="_psGroupBy" disabled="@_psLoading">
                        <option value="route">🗺 Tuyến</option>
                        <option value="province">🏙 Tỉnh/TP</option>
                        <option value="sm">👤 SM</option>
                    </select>

                    <select class="form-select form-select-sm ps-select" @bind="_psTopN" disabled="@_psLoading">
                        <option value="5">Top 5</option>
                        <option value="10">Top 10</option>
                        <option value="15">Top 15</option>
                    </select>

                    <button class="btn btn-sm btn-warning d-flex align-items-center gap-1"
                            @onclick="LoadProductDataAsync" disabled="@_psLoading">
                        @if (_psLoading)
                        { <span class="spinner-border spinner-border-sm"></span> }
                        else
                        { <i class="bi bi-search"></i> }
                        <span>Phân tích</span>
                    </button>

                    @if (_psData.Count > 0)
                    {
                        <div class="ps-metric-toggle">
                            <button class="@(_psMetric=="qty"?"active":"")"    @onclick='()=>SwitchPsMetricAsync("qty")'><i class="bi bi-boxes me-1"></i>SL</button>
                            <button class="@(_psMetric=="amount"?"active":"")" @onclick='()=>SwitchPsMetricAsync("amount")'><i class="bi bi-currency-dollar me-1"></i>DS</button>
                        </div>
                    }

                    <button class="btn btn-sm btn-outline-secondary ms-auto p-1"
                            @onclick="() => _showProductPanel = false">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                @* Body: left = area chart, right = trend *@
                <div class="map-ps-body">

                    @* Grouped bar *@
                    <div class="map-ps-area-wrap">
                        @if (_psLoading)
                        {
                            <div class="map-ps-placeholder">
                                <div class="spinner-border text-warning"></div>
                                <div class="mt-2 text-muted" style="font-size:.8rem">Đang tải…</div>
                            </div>
                        }
                        else if (_psData.Count == 0)
                        {
                            <div class="map-ps-placeholder text-muted">
                                <i class="bi bi-box-seam display-6 opacity-25 d-block mb-2"></i>
                                Chọn kỳ và nhấn <strong>Phân tích</strong>
                            </div>
                        }
                        else
                        {
                            <canvas id="ps-map-area"></canvas>
                        }
                    </div>

                    @* Trend + prediction *@
                    <div class="map-ps-trend-wrap">
                        @if (_psData.Count > 0)
                        {
                            <div class="d-flex align-items-center gap-2 mb-1 flex-shrink-0">
                                <i class="bi bi-graph-up-arrow text-warning" style="font-size:.85rem"></i>
                                <span style="font-size:.78rem;font-weight:700">Xu hướng</span>
                                <select class="form-select form-select-sm ps-select"
                                        style="width:auto;max-width:190px"
                                        @bind="_psSelectedProd"
                                        @bind:after="LoadPsTrendAsync">
                                    @foreach (var cd in PsTopProducts)
                                    {
                                        var lbl = _psProductNames.TryGetValue(cd, out var n) && n != cd
                                            ? $"{cd} – {n}" : cd;
                                        <option value="@cd">@lbl</option>
                                    }
                                </select>
                            </div>

                            @if (_psTrendLoading)
                            {
                                <div class="map-ps-placeholder" style="min-height:80px">
                                    <div class="spinner-border spinner-border-sm text-warning"></div>
                                </div>
                            }
                            else
                            {
                                <div class="map-ps-trend-chart">
                                    <canvas id="ps-map-trend"></canvas>
                                </div>
                            }

                            @if (_psForecast != null)
                            {
                                <div class="d-flex align-items-center gap-1 mb-1 flex-shrink-0">
                                    <span class="algo-badge @_psForecast.AlgorithmBadgeClass">
                                        <i class="bi @_psForecast.AlgorithmIcon"></i>
                                        @(_psForecast.IsSSA ? "ML.NET SSA" : "Linear Regression")
                                    </span>
                                    <span class="algo-detail">@_psForecast.AlgorithmLabel</span>
                                </div>
                            }
                            @if (_psPredictions.Count > 0)
                            {
                                <div class="ps-pred-cards mt-1">
                                    @foreach (var pred in _psPredictions)
                                    {
                                        <div class="ps-pred-card ps-pred-card--@pred.Signal">
                                            <div class="ps-pred-period">@pred.Label</div>
                                            <div class="ps-pred-val" style="font-size:.85rem">
                                                @(_psMetric == "amount"
                                                    ? FormatMoney(pred.Amount)
                                                    : pred.Qty.ToString("N0"))
                                                <span class="ps-pred-unit">@(_psMetric == "amount" ? "đ" : "SP")</span>
                                            </div>
                                            <div class="ps-pred-signal">
                                                <i class="bi @pred.SignalIcon me-1"></i>@pred.SignalText
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="map-ps-placeholder text-muted" style="font-size:.8rem">
                                <i class="bi bi-arrow-left-circle me-1"></i>Tải dữ liệu để xem xu hướng
                            </div>
                        }
                    </div>
                </div>

                @* Strategy table *@
                @if (_psStrategyRowsCache.Count > 0)
                {
                    <div class="map-ps-strategy">
                        <table class="ps-strategy-table">
                            <thead>
                                <tr>
                                    <th>Khu vực</th>
                                    <th>SP bán chạy nhất</th>
                                    <th class="text-end">Số lượng</th>
                                    <th class="text-end">Doanh số</th>
                                    <th>Xu hướng</th>
                                    <th>Gợi ý</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _psStrategyRowsCache)
                                {
                                    <tr>
                                        <td><span class="ps-area-badge">@row.Area</span></td>
                                        <td>
                                            <span class="ps-prod-badge" title="@row.TopCD">
                                                @row.TopName
                                            </span>
                                        </td>
                                        <td class="text-end fw-semibold">@row.Qty.ToString("N0")</td>
                                        <td class="text-end">@FormatMoney(row.Amount)</td>
                                        <td>
                                            <span class="ps-trend-badge ps-trend-badge--@row.TrendClass">
                                                <i class="bi @row.TrendIcon me-1"></i>@row.TrendText
                                            </span>
                                        </td>
                                        <td class="ps-suggest-cell">@row.Suggestion</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>

    @* ── Sidebar ── *@
    @if (_locations.Count > 0)
    {
        <div class="map-sidebar">
            <div class="map-sidebar-header">
                <i class="bi bi-list-ul me-1"></i>Danh sách
                <span class="badge bg-primary ms-1">@FilteredLocations.Count()</span>
                @if (_routeInfo != null)
                {
                    <button class="btn btn-xs btn-outline-danger ms-auto py-0 px-1"
                            style="font-size:.65rem" @onclick="ClearRouteAsync">
                        <i class="bi bi-x"></i> Xoá lộ trình
                    </button>
                }
            </div>
            <div class="map-sidebar-body">
                @{ int idx = 0; }
                @foreach (var loc in FilteredLocations)
                {
                    var c       = IndexColor(idx);
                    var isRoute = _routeInfo?.UserName == loc.UserName;
                    _addresses.TryGetValue(loc.UserName, out var addr);

                    <div class="map-sidebar-item @(isRoute ? "map-sidebar-item--active" : "")"
                         @onclick="() => FlyToAsync(loc)">
                        <div class="map-sidebar-dot" style="background:@c"></div>
                        <div class="map-sidebar-info">
                            <div class="d-flex align-items-center gap-1">
                                <div class="map-sidebar-name">@loc.UserName</div>
                                @* Nút lộ trình *@
                                <button class="map-route-btn @(isRoute ? "map-route-btn--active" : "")"
                                        title="@(isRoute ? "Đang xem lộ trình" : "Xem lộ trình di chuyển")"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => ShowRouteAsync(loc, idx)">
                                    @if (_routeLoading && _routeLoadingUser == loc.UserName)
                                    {
                                        <span class="spinner-border spinner-border-sm"
                                              style="width:.7rem;height:.7rem;border-width:1.5px"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-signpost-2-fill"></i>
                                    }
                                </button>
                            </div>
                            <div class="map-sidebar-time">
                                <i class="bi bi-clock me-1"></i>@loc.Checktime.ToString("HH:mm:ss")
                            </div>
                            @if (addr != null)
                            {
                                <div class="map-sidebar-addr" title="@addr">@addr</div>
                            }
                            else if (_geocodingStarted)
                            {
                                <div class="map-sidebar-addr map-sidebar-addr--loading">Đang lấy địa chỉ…</div>
                            }
                            @if (_sales.TryGetValue(loc.UserName, out var sale) && sale > 0)
                            {
                                <div class="map-sidebar-sales">
                                    <i class="bi bi-graph-up-arrow me-1"></i>@FormatMoney(sale)
                                </div>
                            }
                        </div>
                        <i class="bi bi-chevron-right text-muted" style="font-size:.65rem;flex-shrink:0"></i>
                    </div>
                    idx++;
                }
            </div>
        </div>
    }
</div>

@code {
    // ── State ────────────────────────────────────────────
    private DateTime _date      = DateTime.Today;
    private bool     _loading;
    private bool     _mapReady;
    private bool     _geocodingStarted;
    private int      _geocodedCount;
