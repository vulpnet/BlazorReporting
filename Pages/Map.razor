    private async Task LoadProductDataAsync()
    {
        _psLoading        = true;
        _psAreaNeedsDraw  = false;
        _psTrendNeedsDraw = false;
        _psData           = [];
        _psTrendPoints    = [];
        _psPredictions    = [];
        try { await JS.InvokeVoidAsync("productChartInterop.destroyAll"); } catch { }
        StateHasChanged();

        try
        {
            int? q = _psPeriodType == "quarter" ? _psPeriodValue : null;
            int? m = _psPeriodType == "month"   ? _psPeriodValue : null;
            _psData = await Repo.GetProductSalesByAreaAsync(_psYear, q, m, _psGroupBy, _psTopN);

            if (_psData.Count > 0)
            {
                RebuildPsCache();
                _psSelectedProd  = PsTopProducts.FirstOrDefault() ?? "";
                _psAreaNeedsDraw = true;
            }
            else _error = "Không có dữ liệu sản phẩm cho kỳ đã chọn.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally
        {
            _psLoading = false;
            StateHasChanged();
            if (!string.IsNullOrEmpty(_psSelectedProd))
                await LoadPsTrendAsync();
        }
    }

    private async Task SwitchPsMetricAsync(string metric)
    {
        _psMetric = metric;
        if (_psData.Count > 0)
        {
            RebuildPsCache();           // cập nhật strategy theo metric mới
            _psAreaNeedsDraw  = true;
            _psTrendNeedsDraw = _psTrendPoints.Count > 0;
        }
        StateHasChanged();
    }

    private async Task LoadPsTrendAsync()
    {
        if (string.IsNullOrEmpty(_psSelectedProd)) return;
        _psTrendLoading   = true;
        _psTrendNeedsDraw = false;
        _psPredictions    = [];
        StateHasChanged();
        try
        {
            _psTrendPoints = await Repo.GetProductTrendAsync([_psSelectedProd], 13);
            if (_psTrendPoints.Count > 0)
            {
                // ML.NET SSA forecasting (singleton service, thread-safe)
                _psForecast       = await Task.Run(() => Forecaster.Forecast(_psTrendPoints, 3));
                _psPredictions    = BuildPsPredictions(_psForecast);
                _psTrendNeedsDraw = true;
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _psTrendLoading = false; StateHasChanged(); }
    }

    private ForecastResult? _psForecast;

    private static List<PsPrediction> BuildPsPredictions(ForecastResult fc)
    {
        var result = new List<PsPrediction>();
        for (int i = 0; i < fc.Labels.Count; i++)
        {
            var predQ = (long)fc.Qty.Predicted[i];
            var predA = (decimal)fc.Amount.Predicted[i];
            var loQ   = (long)fc.Qty.Lower[i];
            var hiQ   = (long)fc.Qty.Upper[i];

            // So sánh dự đoán với lower bound để xác định tín hiệu
            var sig = predQ > hiQ * 0.9f ? "up"
                    : predQ < loQ * 1.1f ? "down" : "flat";

            // So sánh với điểm trước trong chuỗi dự đoán
            if (i > 0)
            {
                var prev = (long)fc.Qty.Predicted[i - 1];
                sig = predQ > prev * 1.03f ? "up"
                    : predQ < prev * 0.97f ? "down" : "flat";
            }

            var (icon, txt) = sig switch
            {
                "up"   => ("bi-arrow-up-right-circle-fill",   "Tăng"),
                "down" => ("bi-arrow-down-right-circle-fill", "Giảm"),
                _      => ("bi-dash-circle-fill",              "Ổn định")
            };
            result.Add(new PsPrediction(fc.Labels[i], predQ, predA, sig, icon, txt));
        }
        return result;
    }

