        await ShowRouteAsync(loc, idx);
    }

    // ── Hiện lộ trình ────────────────────────────────────
    private async Task ShowRouteAsync(SalesmanLocation loc, int colorIdx)
    {
        // Nếu đang xem lộ trình của SM này → toggle tắt
        if (_routeInfo?.UserName == loc.UserName)
        {
            await ClearRouteAsync();
            return;
        }

        _routeLoading     = true;
        _routeLoadingUser = loc.UserName;
        _routeColorIdx    = colorIdx;
        StateHasChanged();

        try
        {
            // Dùng route có kèm thông tin KH
            var route = await Repo.GetSalesmanRouteWithSalesAsync(loc.UserName, _date);
            if (route.Count == 0)
            {
                _error = $"Không có dữ liệu lộ trình cho {loc.UserName}";
                return;
            }

            // Serialize kèm visit data
            var pts = route.Select(r => new
            {
                userName  = r.UserName,
                checktime = r.Checktime.ToString("HH:mm:ss"),
                lat       = r.Lattitude,
                lng       = r.Longtitude,
                visit     = r.Visit == null ? null : new
                {
                    customerCD   = r.Visit.CustomerCD,
                    locationName = r.Visit.LocationName,
                    routeCode    = r.Visit.RouteCode,
                    orderAmount  = r.Visit.OrderAmount,
                    orderDate    = r.Visit.OrderDate.ToString("HH:mm:ss")
                }
            });
            var json = JsonSerializer.Serialize(pts,
                new JsonSerializerOptions { PropertyNamingPolicy = null });

            await JS.InvokeVoidAsync("mapInterop.drawRoute", json);

            // Tính km + đếm điểm KH
            var km = 0.0;
            for (int i = 1; i < route.Count; i++)
                km += Haversine(route[i-1].Lattitude, route[i-1].Longtitude,
                                route[i].Lattitude,   route[i].Longtitude);

            var custStops  = route.Count(r => r.Visit != null);
            var totalSales = route.Where(r => r.Visit != null)
                                  .Sum(r => r.Visit!.OrderAmount);
            var timeRange  = route.Count >= 2
                ? $"{route[0].Checktime:HH:mm} → {route[^1].Checktime:HH:mm}"
                : route[0].Checktime.ToString("HH:mm");

            _routeInfo = new RouteInfo(loc.UserName, route.Count, timeRange,
                                       Math.Round(km, 1), custStops, totalSales);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally
        {
            _routeLoading     = false;
            _routeLoadingUser = null;
            StateHasChanged();
        }
    }

