@inherits LayoutComponentBase
@using BlazorReporting.Services
@using BlazorReporting.Data
@using BlazorReporting.Data.Models
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using BlazorReporting.Components
@inject AuthService Auth
@inject NavigationManager Nav
@inject ProtectedLocalStorage Store
@inject IDataRepository Repo

@if (!Auth.IsInitialized)
{
    <div style="min-height:100vh;background:#f8fafc"></div>
}
else if (!Auth.IsLoggedIn)
{
    Nav.NavigateTo("/", forceLoad: false);
}
else
{
    <div class="d-flex flex-column min-vh-100">

        <nav class="navbar navbar-expand-md navbar-dark px-3 py-2" style="background:#1a1a2e">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/report">
                <div style="width:28px;height:28px;border-radius:6px;
                            background:linear-gradient(135deg,#4f46e5,#7c3aed);
                            display:flex;align-items:center;justify-content:center;font-size:.9rem">
                    <i class="bi bi-bar-chart-line-fill"></i>
                </div>
                <span class="d-none d-sm-inline" style="font-size:.95rem;letter-spacing:.02em">
                    DMSPRO <span style="font-weight:300;opacity:.7">Reporting</span>
                </span>
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mt-2 mt-md-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/report">
                            <i class="bi bi-table me-1"></i>Báo cáo
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/map">
                            <i class="bi bi-geo-alt me-1"></i>Bản đồ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/product-sales">
                            <i class="bi bi-box-seam me-1"></i>Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/sales-strategy">
                            <i class="bi bi-robot me-1"></i>Chiến lược
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/help" target="_blank">
                            <i class="bi bi-question-circle me-1"></i>Hướng dẫn
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav mt-2 mt-md-0 align-items-md-center gap-2">
                    <li class="nav-item d-flex align-items-center gap-2">
                        <div class="nav-user-avatar">
                            @(Auth.FullName.Length > 0 ? Auth.FullName[0].ToString().ToUpper() : "U")
                        </div>
                        <div class="d-none d-md-block">
                            <div style="font-size:.8rem;color:#e2e8f0;line-height:1.1">@Auth.FullName</div>
                            <div style="font-size:.68rem;color:#94a3b8">@Auth.Role</div>
                        </div>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-sm nav-logout-btn" @onclick="LogoutAsync">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            <span class="d-none d-md-inline">Đăng xuất</span>
                        </button>
                    </li>
                </ul>
            </div>
        </nav>

        <main class="flex-grow-1 overflow-hidden">
            @Body
        </main>

        <footer class="text-center text-muted py-2 border-top"
                style="font-size:.72rem;background:#f8fafc">
            DMSPRO Reporting &copy; @DateTime.Now.Year
        </footer>
    </div>

    @* ── AI Chatbox — hiện trên mọi trang đã đăng nhập ── *@
    <ChatWindow ReportLinks="@_reportLinks" />
}

<div id="blazor-error-ui" class="alert alert-danger m-2"
     style="display:none;position:fixed;bottom:1rem;left:1rem;right:1rem;z-index:9999">
    Có lỗi xảy ra. <a href="" class="alert-link">Tải lại</a>
</div>

@code {
    private IReadOnlyList<ChatNavLink> _reportLinks = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Restore session
        if (!Auth.IsInitialized)
        {
            try
            {
                var result = await Store.GetAsync<AuthSession>("dmspro_auth");
                if (result.Success && result.Value is not null)
                    Auth.Restore(result.Value);
                else
                    Auth.MarkInitialized();
            }
            catch { Auth.MarkInitialized(); }

            StateHasChanged();
        }

        // Load report catalog cho chatbot (non-blocking)
        _ = LoadReportLinksAsync();
    }

    private async Task LoadReportLinksAsync()
    {
        try
        {
            var cfg = new DataSourceConfig
            {
                Source     = "DMSViewReportTemplate",
                SourceType = DataSourceType.View,
                PageSize   = 1000
            };
            var rows = await Repo.FetchAllAsync(cfg);

            var nameKeys   = new[] { "ReportName","Name","Title","DisplayName","RPT_NAME","REPORT_NAME" };
            var sourceKeys = new[] { "SourceName","Source","ObjectName","SPName","ProcName","ViewName","TableName","RPT_SOURCE" };
            var typeKeys   = new[] { "SourceType","Type","ObjectType","RPT_TYPE","SourceKind" };

            // Bước 1: build danh sách cơ bản
            var drafts = new List<(string Name, string Source, string TypeStr)>();
            foreach (var row in rows)
            {
                var name   = Pick(row, nameKeys);
                var source = Pick(row, sourceKeys);
                if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(source)) continue;

                var typeStr = Pick(row, typeKeys)?.Trim().ToLower() switch
                {
                    "sp" or "storedprocedure" or "procedure" or "proc" => "SP",
                    "view" or "vw"                                      => "View",
                    "table" or "tbl"                                    => "Table",
                    _                                                   => InferType(source)
                };
                drafts.Add((name, source, typeStr));
            }

            // Bước 2: fetch SP params song song cho tất cả SP
            var spTasks = drafts
                .Where(d => d.TypeStr == "SP")
                .ToDictionary(
                    d => d.Source,
                    d => Repo.GetSpParametersAsync(d.Source));

            await Task.WhenAll(spTasks.Values);

            // Bước 3: gộp lại thành ChatNavLink
            var links = drafts.Select(d =>
            {
                var url = $"/report?Source={d.Source}&Type={d.TypeStr}";

                IReadOnlyList<SpParamInfo>? spParams = null;
                if (d.TypeStr == "SP" && spTasks.TryGetValue(d.Source, out var t) && t.IsCompletedSuccessfully)
                {
                    spParams = t.Result
                        .Select(p => new SpParamInfo(p.Name, p.TypeName, !p.HasDefault))
                        .ToList();
                }

                return new ChatNavLink(d.Name, url, spParams);
            }).ToList();

            _reportLinks = links;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* DMSViewReportTemplate không tồn tại — bỏ qua */ }
    }

    private static string? Pick(Dictionary<string, object?> row, string[] keys)
    {
        foreach (var k in keys)
            if (row.TryGetValue(k, out var v) && v != null)
                return v.ToString();
        return null;
    }

    private static string InferType(string source)
    {
        var s = source.ToLower();
        if (s.StartsWith("sp_") || s.StartsWith("usp_") || s.StartsWith("proc_")) return "SP";
        if (s.StartsWith("vw_") || s.StartsWith("view_") || s.StartsWith("v_"))   return "View";
        return "View";
    }

    private async Task LogoutAsync()
    {
        try { await Store.DeleteAsync("dmspro_auth"); } catch { }
        Auth.Logout();
        Nav.NavigateTo("/");
    }
}
