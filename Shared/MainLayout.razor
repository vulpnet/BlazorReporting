@inherits LayoutComponentBase
@using BlazorReporting.Services
@using BlazorReporting.Data
@using BlazorReporting.Data.Models
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using BlazorReporting.Components
@inject AuthService Auth
@inject NavigationManager Nav
@inject ProtectedLocalStorage Store
@inject IDataRepository Repo
@inject NavMenuService MenuSvc
@implements IDisposable

@if (!Auth.IsInitialized)
{
    <div style="min-height:100vh;background:#f1f5f9"></div>
}
else if (!Auth.IsLoggedIn)
{
    Nav.NavigateTo("/", forceLoad: false);
}
else
{
    <div class="dm-shell @(_collapsed ? "is-collapsed" : "") @(_mobileOpen ? "is-mobile-open" : "")">

        <Sidebar Collapsed="_collapsed" CollapsedChanged="OnCollapsedChanged" OnLogout="LogoutAsync" />

        <div class="dm-shell__main">

            <header class="dm-topbar">
                <button class="dm-topbar__toggle dm-only-desktop" @onclick="ToggleCollapse"
                        title="@(_collapsed ? "Mở rộng menu" : "Thu gọn menu")">
                    <i class="bi @(_collapsed ? "bi-chevron-double-right" : "bi-chevron-double-left")"></i>
                </button>
                <button class="dm-topbar__toggle dm-only-mobile" @onclick="() => _mobileOpen = !_mobileOpen"
                        title="Menu">
                    <i class="bi bi-list"></i>
                </button>

                <div class="dm-topbar__title">
                    <span class="dm-topbar__crumb">@CurrentGroup</span>
                    @CurrentTitle
                </div>

                <a class="btn btn-sm btn-light border" href="/help" target="_blank" title="Hướng dẫn">
                    <i class="bi bi-question-circle"></i>
                </a>
            </header>

            <main class="dm-content">
                @Body
            </main>

            <footer class="dm-footer">
                DMSPRO Reporting &copy; @DateTime.Now.Year &middot; v1.0
            </footer>
        </div>
    </div>

    <ChatWindow ReportLinks="@_reportLinks" />
}

<div id="blazor-error-ui" class="alert alert-danger m-2"
     style="display:none;position:fixed;bottom:1rem;left:1rem;right:1rem;z-index:9999">
    Có lỗi xảy ra. <a href="" class="alert-link">Tải lại</a>
</div>

@code {
    private IReadOnlyList<ChatNavLink> _reportLinks = [];
    private bool _collapsed;
    private bool _mobileOpen;

    private string CurrentTitle => CurrentItem()?.Title ?? "Trang chủ";
    private string CurrentGroup => CurrentItem()?.Group ?? "";

    private NavMenuItem? CurrentItem()
    {
        var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        if (string.IsNullOrEmpty(path)) path = "/";
        return MenuSvc.GetMenu(Auth.Role)
            .SelectMany(g => g.Items)
            .FirstOrDefault(i => string.Equals(i.Href.TrimEnd('/'), path, StringComparison.OrdinalIgnoreCase));
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? s, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _mobileOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!Auth.IsInitialized)
        {
            try
            {
                var result = await Store.GetAsync<AuthSession>("dmspro_auth");
                if (result.Success && result.Value is not null)
                    Auth.Restore(result.Value);
                else
                    Auth.MarkInitialized();
            }
            catch { Auth.MarkInitialized(); }

            StateHasChanged();
        }

        // Restore sidebar collapsed pref
        try
        {
            var col = await Store.GetAsync<bool>("dmspro_sidebar_collapsed");
            if (col.Success && col.Value != _collapsed)
            {
                _collapsed = col.Value;
                StateHasChanged();
            }
        }
        catch { }

        _ = LoadReportLinksAsync();
    }

    private async Task OnCollapsedChanged(bool v)
    {
        _collapsed = v;
        try { await Store.SetAsync("dmspro_sidebar_collapsed", v); } catch { }
    }

    private Task ToggleCollapse() => OnCollapsedChanged(!_collapsed);

    private async Task LoadReportLinksAsync()
    {
        try
        {
            var cfg = new DataSourceConfig
            {
                Source     = "DMSViewReportTemplate",
                SourceType = DataSourceType.View,
                PageSize   = 1000
            };
            var rows = await Repo.FetchAllAsync(cfg);

            var nameKeys   = new[] { "ReportName","Name","Title","DisplayName","RPT_NAME","REPORT_NAME" };
            var sourceKeys = new[] { "SourceName","Source","ObjectName","SPName","ProcName","ViewName","TableName","RPT_SOURCE" };
            var typeKeys   = new[] { "SourceType","Type","ObjectType","RPT_TYPE","SourceKind" };

            var drafts = new List<(string Name, string Source, string TypeStr)>();
            foreach (var row in rows)
            {
                var name   = Pick(row, nameKeys);
                var source = Pick(row, sourceKeys);
                if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(source)) continue;

                var typeStr = Pick(row, typeKeys)?.Trim().ToLower() switch
                {
                    "sp" or "storedprocedure" or "procedure" or "proc" => "SP",
                    "view" or "vw"                                      => "View",
                    "table" or "tbl"                                    => "Table",
                    _                                                   => InferType(source)
                };
                drafts.Add((name, source, typeStr));
            }

            var spTasks = drafts
                .Where(d => d.TypeStr == "SP")
                .ToDictionary(
                    d => d.Source,
                    d => Repo.GetSpParametersAsync(d.Source));

            await Task.WhenAll(spTasks.Values);

            var links = drafts.Select(d =>
            {
                var url = $"/report?Source={d.Source}&Type={d.TypeStr}";

                IReadOnlyList<SpParamInfo>? spParams = null;
                if (d.TypeStr == "SP" && spTasks.TryGetValue(d.Source, out var t) && t.IsCompletedSuccessfully)
                {
                    spParams = t.Result
                        .Select(p => new SpParamInfo(p.Name, p.TypeName, !p.HasDefault))
                        .ToList();
                }

                return new ChatNavLink(d.Name, url, spParams);
            }).ToList();

            _reportLinks = links;
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private static string? Pick(Dictionary<string, object?> row, string[] keys)
    {
        foreach (var k in keys)
            if (row.TryGetValue(k, out var v) && v != null)
                return v.ToString();
        return null;
    }

    private static string InferType(string source)
    {
        var s = source.ToLower();
        if (s.StartsWith("sp_") || s.StartsWith("usp_") || s.StartsWith("proc_")) return "SP";
        if (s.StartsWith("vw_") || s.StartsWith("view_") || s.StartsWith("v_"))   return "View";
        return "View";
    }

    private async Task LogoutAsync()
    {
        try { await Store.DeleteAsync("dmspro_auth"); } catch { }
        Auth.Logout();
        Nav.NavigateTo("/");
    }
}
